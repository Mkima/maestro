        "duration_minutes": 2,
        "requirements": {
          "tools": ["כף"],
          "heat_source": "none",
          "temp_celsius": null
        },
        "concurrent_friendly": true,
        "dependencies": []
      },
      {
        "step_id": "s11",
        "instruction": "אוטמים בעזרת נייר אפייה ומעליו רדיד אלומיניום או סוגרים עם מכסה המתאים לתנור. חשוב שהאיטום עם רדיד האלומיניום יהיה יסודי.",
        "category": "active", 
        "duration_minutes": 5,
        "requirements": {
          "tools": [" giấy אפייה", "רדיד אלומיניום"],
          "heat_source": "none",
          "temp_celsius": null
        },
        "concurrent_friendly": true,
        "dependencies": []
      },
      {
        "step_id": "s12",
        "instruction": "מבשלים בתנור: מביאים לתנור (160 מעלות) למשך 3-4 שעות, או עד שהבשר התרכך ונהיה נימוח וכל הירקות מבושלים לחלוטין.",
        "category": "passive",
        "duration_minutes": 180,
        "requirements": {
          "tools": [" духов"],
          "heat_source": "oven",
          "temp_celsius": 160
        },
        "concurrent_friendly": true,
        "dependencies": []
      },
      {
        "step_id": "s13", 
        "instruction": "אם בתום זמן האפייה הבשר עדיין לא רך, סוגרים שוב את הסיר ואופים שעה נוספת, או יותר, בסוף הוא יתרכך.",
        "category": "passive",
        "duration_minutes": 60,
        "requirements": {
          "tools": [" духов"],
